{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redshield.dev/schemas/elements.schema.json",
  "title": "RedShield Model Elements",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "elements"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "name"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["actor", "use_case", "class", "component", "activity", "sequence_participant"] },
          "name": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "description": { "type": "string" },
          "documentation": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "proposed", "accepted", "deprecated", "retired"] },
          "stereotypes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "provenance": { "$ref": "#/$defs/provenance" },
          "externalReferences": {
            "type": "array",
            "items": { "$ref": "#/$defs/externalReference" }
          },
          "architecture": { "$ref": "#/$defs/architectureDetails" },
          "classifier": { "$ref": "#/$defs/classifierDetails" },
          "actorDetails": { "$ref": "#/$defs/actorDetails" },
          "useCaseDetails": { "$ref": "#/$defs/useCaseDetails" },
          "activityDetails": { "$ref": "#/$defs/activityDetails" },
          "sequenceParticipantDetails": { "$ref": "#/$defs/sequenceParticipantDetails" }
        },
        "allOf": [
          {
            "if": { "required": ["classifier"] },
            "then": {
              "properties": {
                "kind": { "enum": ["class", "component"] }
              }
            }
          },
          {
            "if": { "required": ["actorDetails"] },
            "then": { "properties": { "kind": { "const": "actor" } } }
          },
          {
            "if": { "required": ["useCaseDetails"] },
            "then": { "properties": { "kind": { "const": "use_case" } } }
          },
          {
            "if": { "required": ["activityDetails"] },
            "then": { "properties": { "kind": { "const": "activity" } } }
          },
          {
            "if": { "required": ["sequenceParticipantDetails"] },
            "then": { "properties": { "kind": { "const": "sequence_participant" } } }
          }
        ]
      }
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "createdBy": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "externalReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "uri"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 }
      }
    },
    "architectureDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owners": {
          "type": "array",
          "items": { "$ref": "#/$defs/architectureOwner" }
        },
        "lifecycle": { "$ref": "#/$defs/architectureLifecycle" },
        "criticality": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "technologies": {
          "type": "array",
          "items": { "$ref": "#/$defs/technologyMapping" }
        },
        "risks": {
          "type": "array",
          "items": { "$ref": "#/$defs/riskMapping" }
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityMapping" }
        },
        "services": {
          "type": "array",
          "items": { "$ref": "#/$defs/serviceMapping" }
        }
      }
    },
    "architectureOwner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": ["accountable", "responsible", "technical", "business", "support"]
        },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "architectureLifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "enum": ["idea", "planned", "active", "deprecated", "retiring", "retired"]
        },
        "phase": { "type": "string", "minLength": 1 },
        "milestoneRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "targetDate": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "technologyMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": ["platform", "runtime", "framework", "database", "protocol", "tool", "standard"]
        },
        "version": { "type": "string", "minLength": 1 },
        "standardState": {
          "type": "string",
          "enum": ["approved", "tolerated", "discouraged", "banned", "emerging"]
        }
      }
    },
    "riskMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "status": {
          "type": "string",
          "enum": ["identified", "accepted", "mitigating", "mitigated", "closed"]
        },
        "notes": { "type": "string" }
      }
    },
    "capabilityMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "fit": {
          "type": "string",
          "enum": ["primary", "supporting", "enabling", "impacted"]
        },
        "maturity": {
          "type": "string",
          "enum": ["emerging", "developing", "established", "optimized", "legacy"]
        }
      }
    },
    "serviceMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "relationship": {
          "type": "string",
          "enum": ["provides", "consumes", "depends_on", "exposes", "supports"]
        },
        "interfaceRef": { "type": "string", "minLength": 1 }
      }
    },
    "classifierDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "isAbstract": { "type": "boolean" },
        "isStatic": { "type": "boolean" },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/classifierAttribute" }
        },
        "operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/classifierOperation" }
        }
      }
    },
    "classifierAttribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "visibility": { "$ref": "#/$defs/visibility" },
        "typeRef": { "type": "string", "minLength": 1 },
        "multiplicity": { "$ref": "#/$defs/multiplicity" },
        "defaultValue": { "type": "string" },
        "isStatic": { "type": "boolean" },
        "isReadOnly": { "type": "boolean" },
        "documentation": { "type": "string" }
      }
    },
    "classifierOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "visibility": { "$ref": "#/$defs/visibility" },
        "returnTypeRef": { "type": "string", "minLength": 1 },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/operationParameter" }
        },
        "isAbstract": { "type": "boolean" },
        "isStatic": { "type": "boolean" },
        "documentation": { "type": "string" }
      }
    },
    "operationParameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "typeRef": { "type": "string", "minLength": 1 },
        "direction": { "type": "string", "enum": ["in", "out", "inout", "return"] },
        "multiplicity": { "$ref": "#/$defs/multiplicity" },
        "defaultValue": { "type": "string" }
      }
    },
    "multiplicity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lower": { "type": "integer", "minimum": 0 },
        "upper": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": "*" }
          ]
        },
        "isOrdered": { "type": "boolean" },
        "isUnique": { "type": "boolean" }
      }
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "private", "protected", "package"]
    },
    "actorDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actorType": {
          "type": "string",
          "enum": ["person", "role", "organization", "system", "external_system"]
        },
        "responsibilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "goals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "useCaseDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primaryActorRef": { "type": "string", "minLength": 1 },
        "supportingActorRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "preconditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "postconditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "mainFlow": {
          "type": "array",
          "items": { "$ref": "#/$defs/useCaseStep" }
        },
        "alternateFlows": {
          "type": "array",
          "items": { "$ref": "#/$defs/useCaseAlternateFlow" }
        },
        "extensionPoints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "useCaseStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "action"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "actorRef": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 }
      }
    },
    "useCaseAlternateFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "steps"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "trigger": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/useCaseStep" }
        }
      }
    },
    "activityDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/activityParameter" }
        },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/activityNode" }
        },
        "flows": {
          "type": "array",
          "items": { "$ref": "#/$defs/activityFlow" }
        }
      }
    },
    "activityParameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "typeRef": { "type": "string", "minLength": 1 },
        "direction": { "type": "string", "enum": ["in", "out", "inout"] }
      }
    },
    "activityNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["initial", "action", "decision", "merge", "fork", "join", "object", "final"]
        },
        "description": { "type": "string" }
      }
    },
    "activityFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sourceNodeId", "targetNodeId"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sourceNodeId": { "type": "string", "minLength": 1 },
        "targetNodeId": { "type": "string", "minLength": 1 },
        "guard": { "type": "string", "minLength": 1 }
      }
    },
    "sequenceParticipantDetails": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "participantKind": {
          "type": "string",
          "enum": ["actor", "component", "class", "service", "external_system"]
        },
        "representsRef": { "type": "string", "minLength": 1 },
        "lifelineName": { "type": "string", "minLength": 1 },
        "isExternal": { "type": "boolean" }
      }
    }
  }
}
