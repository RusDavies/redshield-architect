{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redshield.dev/schemas/portfolio-saved-views.schema.json",
  "title": "RedShield Portfolio Saved Views",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "views"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "views": {
      "type": "array",
      "items": { "$ref": "#/$defs/portfolioSavedView" }
    }
  },
  "$defs": {
    "portfolioSavedView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "scope"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "scope": {
          "type": "string",
          "enum": ["portfolio_summary", "portfolio_view_source", "export_set"]
        },
        "resultKinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/portfolioKind" }
        },
        "query": { "$ref": "#/$defs/portfolioSavedViewQuery" },
        "sort": {
          "type": "array",
          "items": { "$ref": "#/$defs/portfolioSavedViewSort" }
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/savedViewColumn" }
        },
        "presentation": { "$ref": "#/$defs/portfolioSavedViewPresentation" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "portfolioSavedViewQuery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/portfolioKind" }
        },
        "statuses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["draft", "proposed", "accepted", "deprecated", "retired"]
          }
        },
        "lifecycleStates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["idea", "planned", "active", "deprecated", "retiring", "retired"]
          }
        },
        "criticalities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        },
        "standardStates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["approved", "tolerated", "discouraged", "banned", "emerging"]
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "ownerRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "capabilityRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "technologyRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "riskRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "relatedElementRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "portfolioSavedViewSort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field"],
      "properties": {
        "field": { "$ref": "#/$defs/savedViewColumn" },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"]
        }
      }
    },
    "portfolioSavedViewPresentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "density": {
          "type": "string",
          "enum": ["compact", "comfortable", "detailed"]
        },
        "groupBy": {
          "type": "string",
          "enum": [
            "kind",
            "status",
            "lifecycleState",
            "criticality",
            "standardState",
            "owner",
            "capability"
          ]
        },
        "showCounts": { "type": "boolean" }
      }
    },
    "savedViewColumn": {
      "type": "string",
      "enum": [
        "id",
        "kind",
        "name",
        "status",
        "lifecycleState",
        "criticality",
        "standardState",
        "ownerRefs",
        "capabilityRefs",
        "technologyRefs",
        "riskRefs",
        "relatedElementRefs",
        "tags"
      ]
    },
    "portfolioKind": {
      "type": "string",
      "enum": [
        "business_capability",
        "portfolio_application",
        "portfolio_service",
        "technology_component",
        "technology_standard",
        "organization_unit",
        "owner",
        "lifecycle_milestone",
        "roadmap_item",
        "risk",
        "control",
        "governance_decision",
        "data_source"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "createdBy": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
