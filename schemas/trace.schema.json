{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redshield.dev/schemas/trace.schema.json",
  "title": "RedShield Trace Links",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "links"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sourceId", "targetId", "traceKind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "sourceId": { "type": "string", "minLength": 1 },
          "targetId": { "type": "string", "minLength": 1 },
          "traceKind": { "type": "string", "enum": ["satisfies", "derived_from", "verifies", "implements"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
