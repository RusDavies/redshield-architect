{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redshield.dev/schemas/diagrams.schema.json",
  "title": "RedShield Diagrams",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "diagrams"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "diagrams": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "viewKind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "viewKind": {
            "type": "string",
            "enum": [
              "use_case",
              "capability_map",
              "application_landscape",
              "lifecycle_roadmap",
              "risk_heatmap",
              "dependency_map"
            ]
          },
          "modelRefs": { "type": "array", "items": { "type": "string" } },
          "portfolioRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "roadmapPresentationRef": { "type": "string", "minLength": 1 },
          "layout": {
            "type": "object",
            "additionalProperties": false,
            "required": ["coordinateSystem", "layoutState", "nodes", "connectors"],
            "properties": {
              "coordinateSystem": { "type": "string", "enum": ["canvas"] },
              "layoutEngine": { "type": "string", "minLength": 1 },
              "layoutState": { "type": "string", "enum": ["generated", "manual", "mixed"] },
              "nodes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["modelRef", "bounds", "layoutState"],
                  "properties": {
                    "modelRef": { "type": "string", "minLength": 1 },
                    "bounds": { "$ref": "#/$defs/bounds" },
                    "layoutState": { "type": "string", "enum": ["generated", "manual"] },
                    "labelPosition": { "$ref": "#/$defs/point" },
                    "style": { "$ref": "#/$defs/style" }
                  }
                }
              },
              "connectors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["relationshipRef", "layoutState"],
                  "properties": {
                    "relationshipRef": { "type": "string", "minLength": 1 },
                    "layoutState": { "type": "string", "enum": ["generated", "manual"] },
                    "routeHint": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["kind"],
                      "properties": {
                        "kind": {
                          "type": "string",
                          "enum": ["straight", "step", "smoothstep", "bezier", "orthogonal"]
                        },
                        "points": {
                          "type": "array",
                          "items": { "$ref": "#/$defs/point" }
                        }
                      }
                    },
                    "labelPosition": { "$ref": "#/$defs/point" },
                    "style": { "$ref": "#/$defs/style" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fillColor": { "$ref": "#/$defs/color" },
        "strokeColor": { "$ref": "#/$defs/color" },
        "textColor": { "$ref": "#/$defs/color" },
        "lineStyle": { "type": "string", "enum": ["solid", "dashed", "dotted"] }
      }
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    }
  }
}
