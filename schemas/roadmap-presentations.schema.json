{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redshield.dev/schemas/roadmap-presentations.schema.json",
  "title": "RedShield Roadmap Presentations",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "presentations"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "presentations": {
      "type": "array",
      "items": { "$ref": "#/$defs/roadmapPresentation" }
    }
  },
  "$defs": {
    "roadmapPresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "appliesToViewKinds"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "appliesToViewKinds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["lifecycle_roadmap"] }
        },
        "timeline": { "$ref": "#/$defs/timeline" },
        "swimlanes": { "$ref": "#/$defs/swimlanes" },
        "targetStates": { "$ref": "#/$defs/targetStates" },
        "milestones": { "$ref": "#/$defs/milestones" },
        "styling": { "$ref": "#/$defs/styling" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bucketSource": {
          "type": "string",
          "enum": ["targetDate", "retirementDate", "endOfSupportDate", "currentFrom", "auto"]
        },
        "bucketGranularity": {
          "type": "string",
          "enum": ["month", "quarter", "half_year", "year"]
        },
        "rangeStart": { "$ref": "#/$defs/date" },
        "rangeEnd": { "$ref": "#/$defs/date" },
        "includeUndatedBucket": { "type": "boolean" },
        "dateLabelFormat": {
          "type": "string",
          "enum": ["date", "month", "quarter", "year"]
        }
      }
    },
    "swimlanes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "groupBy": {
          "type": "string",
          "enum": [
            "portfolioKind",
            "lifecycleState",
            "criticality",
            "owner",
            "capability",
            "technology",
            "none"
          ]
        },
        "order": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "includeEmptyLanes": { "type": "boolean" },
        "fallbackLaneTitle": { "type": "string", "minLength": 1 }
      }
    },
    "targetStates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "showCallouts": { "type": "boolean" },
        "showTargetDates": { "type": "boolean" },
        "showNoChangeTargets": { "type": "boolean" },
        "states": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["planned", "active", "deprecated", "retiring", "retired"]
          }
        }
      }
    },
    "milestones": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "showMilestoneNodes": { "type": "boolean" },
        "showMilestoneLinks": { "type": "boolean" },
        "linkStyle": { "type": "string", "enum": ["solid", "dashed", "dotted"] },
        "includeUnreferencedMilestones": { "type": "boolean" }
      }
    },
    "styling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "density": {
          "type": "string",
          "enum": ["compact", "comfortable", "detailed"]
        },
        "colorBy": {
          "type": "string",
          "enum": ["lifecycleState", "criticality", "standardState", "portfolioKind", "none"]
        },
        "showLegend": { "type": "boolean" },
        "showTimelineScale": { "type": "boolean" }
      }
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "createdBy": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
