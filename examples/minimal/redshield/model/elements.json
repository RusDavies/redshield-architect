{
  "schemaVersion": "0.1.0",
  "elements": [
    {
      "id": "actor.architect",
      "kind": "actor",
      "name": "Architect",
      "aliases": ["Model reviewer"],
      "description": "Human owner of model review and approval.",
      "documentation": "The architect owns review decisions and is the human approval gate for proposal application.",
      "status": "accepted",
      "actorDetails": {
        "actorType": "role",
        "responsibilities": [
          "Review proposed model changes before they become canonical project state"
        ],
        "goals": ["Keep requirements, diagrams, and traceability aligned"],
        "constraints": ["Must preserve human approval over canonical changes"]
      },
      "provenance": {
        "sourceRefs": ["docs/PRODUCT_BRIEF.md"],
        "createdBy": "RedShield prototype seed",
        "createdAt": "2026-07-01T00:00:00Z"
      },
      "externalReferences": [
        {
          "id": "ref.architect-role",
          "label": "Product brief stakeholder",
          "uri": "docs/PRODUCT_BRIEF.md#users--stakeholders",
          "kind": "document"
        }
      ],
      "tags": ["human", "reviewer"]
    },
    {
      "id": "usecase.review-proposal",
      "kind": "use_case",
      "name": "Review proposal",
      "description": "Inspect, validate, and accept or reject proposed model operations.",
      "useCaseDetails": {
        "primaryActorRef": "actor.architect",
        "preconditions": ["A proposal transaction exists in reviewable state"],
        "postconditions": ["Accepted operations are applied through the typed operation API"],
        "mainFlow": [
          {
            "step": 1,
            "actorRef": "actor.architect",
            "action": "Inspect the proposal summary, rationale, source references, and validation result"
          },
          {
            "step": 2,
            "actorRef": "actor.architect",
            "action": "Accept or reject the proposed operations"
          }
        ],
        "alternateFlows": [
          {
            "name": "Validation fails",
            "trigger": "The proposal does not satisfy schema or reference validation",
            "steps": [
              {
                "step": 1,
                "action": "Keep the proposal open for correction without mutating canonical model files"
              }
            ]
          }
        ],
        "extensionPoints": ["Request additional AI rationale before accepting"]
      },
      "tags": ["proposal-review"]
    },
    {
      "id": "usecase.render-diagram",
      "kind": "use_case",
      "name": "Render diagram",
      "description": "Render an accepted semantic model view as SVG.",
      "tags": ["diagram"]
    },
    {
      "id": "component.workbench",
      "kind": "component",
      "name": "Workbench",
      "description": "Interactive diagram surface for reviewing and editing model views.",
      "classifier": {
        "operations": [
          {
            "name": "emitProposalOperation",
            "visibility": "public",
            "returnTypeRef": "ProposalOperation",
            "parameters": [
              {
                "name": "operation",
                "typeRef": "WorkbenchOperation",
                "direction": "in"
              }
            ]
          }
        ]
      },
      "tags": ["ui", "diagram"]
    },
    {
      "id": "class.render-policy",
      "kind": "class",
      "name": "Render Policy",
      "description": "Example class carrying a stereotype that maps to an image-backed renderer.",
      "stereotypes": ["XYZ"],
      "classifier": {
        "isAbstract": false,
        "attributes": [
          {
            "name": "rendererId",
            "visibility": "private",
            "typeRef": "RendererId",
            "multiplicity": {
              "lower": 1,
              "upper": 1
            },
            "isReadOnly": true
          },
          {
            "name": "selectorTags",
            "visibility": "private",
            "typeRef": "String",
            "multiplicity": {
              "lower": 0,
              "upper": "*",
              "isOrdered": true,
              "isUnique": true
            },
            "defaultValue": "[]"
          }
        ],
        "operations": [
          {
            "name": "matches",
            "visibility": "public",
            "returnTypeRef": "Boolean",
            "parameters": [
              {
                "name": "element",
                "typeRef": "ModelElement",
                "direction": "in"
              }
            ]
          }
        ]
      },
      "tags": ["renderer-demo"]
    },
    {
      "id": "activity.review-proposal-flow",
      "kind": "activity",
      "name": "Review proposal flow",
      "description": "Activity-level outline of proposal review.",
      "activityDetails": {
        "parameters": [
          {
            "name": "proposal",
            "typeRef": "ProposalTransaction",
            "direction": "in"
          }
        ],
        "nodes": [
          {
            "id": "activity-node.review-start",
            "name": "Review starts",
            "kind": "initial"
          },
          {
            "id": "activity-node.inspect",
            "name": "Inspect proposal",
            "kind": "action"
          },
          {
            "id": "activity-node.decision",
            "name": "Acceptable?",
            "kind": "decision"
          },
          {
            "id": "activity-node.done",
            "name": "Review complete",
            "kind": "final"
          }
        ],
        "flows": [
          {
            "id": "activity-flow.start-inspect",
            "sourceNodeId": "activity-node.review-start",
            "targetNodeId": "activity-node.inspect"
          },
          {
            "id": "activity-flow.inspect-decision",
            "sourceNodeId": "activity-node.inspect",
            "targetNodeId": "activity-node.decision"
          },
          {
            "id": "activity-flow.decision-done",
            "sourceNodeId": "activity-node.decision",
            "targetNodeId": "activity-node.done",
            "guard": "accepted or rejected"
          }
        ]
      },
      "tags": ["proposal-review", "activity"]
    },
    {
      "id": "participant.architect",
      "kind": "sequence_participant",
      "name": "Architect lifeline",
      "description": "Sequence participant representing the reviewing architect.",
      "sequenceParticipantDetails": {
        "participantKind": "actor",
        "representsRef": "actor.architect",
        "lifelineName": "Architect",
        "isExternal": false
      },
      "tags": ["proposal-review", "sequence"]
    }
  ]
}
